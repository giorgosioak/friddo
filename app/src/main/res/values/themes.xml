<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Friddo" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowContentOverlay">@null</item>

        <!-- Disable translucency to allow solid background colors -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>

        <!-- Optional: Set status bar to transparent so Compose handles the color -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Technical Rigor: Ensure the window doesn't draw its own background
             behind the status bar, which causes the 'white on white' issue -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>